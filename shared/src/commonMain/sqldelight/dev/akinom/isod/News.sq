CREATE TABLE NewsHeaderEntity (
    id                   TEXT NOT NULL PRIMARY KEY,
    semester             TEXT NOT NULL,
    title                TEXT NOT NULL,
    date                 TEXT,
    author               TEXT NOT NULL,
    type                 TEXT NOT NULL,
    label                TEXT NOT NULL,
    hasSentNotification  INTEGER NOT NULL DEFAULT 0,
    lastUpdated          INTEGER NOT NULL
);

CREATE TABLE NewsItemEntity (
    id           TEXT NOT NULL PRIMARY KEY,
    semester     TEXT NOT NULL,
    title                TEXT NOT NULL,
    content      TEXT NOT NULL,
    date                 TEXT,
    author               TEXT NOT NULL,
    type                 TEXT NOT NULL,
    label                TEXT NOT NULL,
    lastUpdated  INTEGER NOT NULL
);

upsertHeader:
INSERT OR REPLACE INTO NewsHeaderEntity VALUES ?;

upsertItem:
INSERT OR REPLACE INTO NewsItemEntity VALUES ?;

selectAllHeaders:
SELECT * FROM NewsHeaderEntity WHERE semester = ? ORDER BY date DESC;

selectItem:
SELECT * FROM NewsItemEntity WHERE id = ?;

deleteAllHeaders:
DELETE FROM NewsHeaderEntity WHERE semester = ?;

headersLastUpdated:
SELECT lastUpdated FROM NewsHeaderEntity WHERE semester = ? LIMIT 1;

selectUnsentNotifications:
SELECT * FROM NewsHeaderEntity WHERE hasSentNotification = 0;

markNotificationSent:
UPDATE NewsHeaderEntity SET hasSentNotification = 1 WHERE id = ?;

markAllNotificationsSent:
UPDATE NewsHeaderEntity SET hasSentNotification = 1;
