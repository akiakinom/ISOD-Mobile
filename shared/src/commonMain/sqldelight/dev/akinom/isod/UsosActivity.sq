CREATE TABLE IF NOT EXISTS UsosActivityEntity (
    id          TEXT    NOT NULL PRIMARY KEY,
    type        TEXT    NOT NULL,
    dayOfWeek   INTEGER NOT NULL,
    startTime   TEXT    NOT NULL,
    endTime     TEXT    NOT NULL,
    name        TEXT    NOT NULL,
    lecturers   TEXT,
    building    TEXT,
    roomNumber  TEXT,
    lastUpdated INTEGER NOT NULL
);

selectByWeek:
SELECT * FROM UsosActivityEntity
WHERE dayOfWeek = :dayOfWeek
ORDER BY startTime ASC;

upsert:
INSERT OR REPLACE INTO UsosActivityEntity VALUES ?;

deleteByWeek:
DELETE FROM UsosActivityEntity
WHERE dayOfWeek = :dayOfWeek;

lastUpdated:
SELECT lastUpdated FROM UsosActivityEntity
WHERE dayOfWeek = :dayOfWeek
LIMIT 1;
