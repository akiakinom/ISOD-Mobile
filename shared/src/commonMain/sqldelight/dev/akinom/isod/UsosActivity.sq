CREATE TABLE IF NOT EXISTS UsosActivityEntity (
    id          TEXT    NOT NULL PRIMARY KEY,  -- composite: courseId_startTime
    type        TEXT    NOT NULL,
    startTime   TEXT    NOT NULL,
    endTime     TEXT    NOT NULL,
    nameJson    TEXT    NOT NULL,              -- LangDict JSON
    courseId    TEXT,
    courseNameJson  TEXT,                      -- LangDict JSON
    classtypeNameJson TEXT,                    -- LangDict JSON
    groupNumber INTEGER,
    lecturersJson TEXT,                        -- List<String> JSON
    buildingNameJson TEXT,                     -- LangDict JSON
    roomNumber  TEXT,
    frequency   TEXT,
    weekStart   TEXT    NOT NULL,              -- "yyyy-mm-dd" of the Monday of this week
    lastUpdated INTEGER NOT NULL
);

selectByWeek:
SELECT * FROM UsosActivityEntity
WHERE weekStart = :weekStart
ORDER BY startTime ASC;

upsert:
INSERT OR REPLACE INTO UsosActivityEntity VALUES ?;

deleteByWeek:
DELETE FROM UsosActivityEntity
WHERE weekStart = :weekStart;

lastUpdated:
SELECT lastUpdated FROM UsosActivityEntity
WHERE weekStart = :weekStart
LIMIT 1;
